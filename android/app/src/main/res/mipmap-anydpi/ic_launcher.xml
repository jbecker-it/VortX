<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive launcher icon (introduced API 26, which is this project's minSdk, so every install
     supports it and no legacy raster fallback or -v26 folder qualifier is needed; a bare
     mipmap-anydpi/ resolves for every device this app targets). monochrome enables Android 13+
     themed icons; ignored gracefully below API 33. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_vortx_mark" />
    <monochrome android:drawable="@drawable/ic_vortx_mark_monochrome" />
</adaptive-icon>
