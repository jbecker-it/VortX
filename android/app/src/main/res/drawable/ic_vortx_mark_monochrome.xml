<?xml version="1.0" encoding="utf-8"?>
<!--
  Monochrome layer for Android 13+ themed (Material You) icons: same mark geometry as
  ic_vortx_mark.xml, but flat opaque fill/stroke instead of the brand gradient: the launcher
  recolors every non-transparent pixel to a single system tone at runtime, so the actual color here
  is irrelevant (opaque black is the convention). Ignored below API 33; harmless to ship at minSdk 26.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path
        android:pathData="M29.9,28.2 C49.0,42.4 56.5,65.6 75.6,79.8"
        android:strokeLineCap="round"
        android:strokeWidth="12.5"
        android:strokeColor="#FF000000"
        android:fillColor="#00000000" />

    <path
        android:pathData="M75.6,28.2 C56.5,42.4 49.0,65.6 29.9,79.8"
        android:strokeLineCap="round"
        android:strokeWidth="12.5"
        android:strokeColor="#FF000000"
        android:fillColor="#00000000" />

    <path
        android:pathData="M52.7,49.4 a4.6,4.6 0,1,1 0,9.2 a4.6,4.6 0,1,1 0,-9.2 z"
        android:fillColor="#FF000000" />
</vector>
