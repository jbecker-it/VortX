<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon background layer: warm radial obsidian, the same gradient DESIGN-SYSTEM.md §2
  "Splash" specifies (#18130c -> #0c0a07). A static drawable, per the adaptive-icon contract (only
  the foreground/monochrome layers may vary; the background never animates or changes at runtime).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="76"
                android:startColor="#18130C"
                android:endColor="#0C0A07" />
        </aapt:attr>
    </path>
</vector>
