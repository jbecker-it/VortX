<?xml version="1.0" encoding="utf-8"?>
<!--
  The VortX mark (DESIGN-SYSTEM.md §2 "The mark"): two woven gradient ribbons crossing to form an X,
  plus a cream center dot. Front ribbon bright gold (#FBBF24 -> #F59E0B -> #D97706) crosses OVER the
  deeper back ribbon (#B45309 -> #7C2D12); geometry mirrors the canonical banner mark in
  docs/vortx-banner.svg, scaled + centered into a 108x108dp viewport so this one asset works both as
  the adaptive-icon foreground (Android crops it to a smaller visible circle, so the mark sits inside
  the ~66dp safe zone) and as the SplashScreen API's windowSplashScreenAnimatedIcon (see
  res/values/themes.xml Theme.VortX.Splash + MainActivity). Do not resize without recomputing the
  transform: it was hand-fit from the original 0..242-space stroke coordinates (scale ~0.4156,
  translate ~2.45,4.13) so both ribbons stay centered and the center dot lands at (52.7, 54).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Back ribbon: the "\" diagonal, drawn first so the front ribbon crosses over it. -->
    <path
        android:pathData="M29.9,28.2 C49.0,42.4 56.5,65.6 75.6,79.8"
        android:strokeLineCap="round"
        android:strokeWidth="12.5"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="52.7" android:startY="20"
                android:endX="52.7" android:endY="88"
                android:startColor="#B45309"
                android:endColor="#7C2D12" />
        </aapt:attr>
    </path>

    <!-- Front ribbon: the "/" diagonal, drawn second so it crosses over the back ribbon. -->
    <path
        android:pathData="M75.6,28.2 C56.5,42.4 49.0,65.6 29.9,79.8"
        android:strokeLineCap="round"
        android:strokeWidth="12.5"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="52.7" android:startY="20"
                android:endX="52.7" android:endY="88"
                android:startColor="#FBBF24"
                android:centerColor="#F59E0B"
                android:centerX="0.55"
                android:endColor="#D97706" />
        </aapt:attr>
    </path>

    <!-- Cream center dot. -->
    <path
        android:pathData="M52.7,49.4 a4.6,4.6 0,1,1 0,9.2 a4.6,4.6 0,1,1 0,-9.2 z"
        android:fillColor="#FDF6E3" />
</vector>
