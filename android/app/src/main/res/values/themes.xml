<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Minimal framework theme to host Compose; no AppCompat/Material-Components dependency. -->
    <style name="Theme.VortX" parent="@android:style/Theme.Material.NoActionBar" />

    <!-- Cold-start splash via the AndroidX SplashScreen API (S01, ANDROID-PLAN.md §0 translation
         table): brand gold mark (ic_vortx_mark, the fixed brand gradient, never the live accent) on
         warm obsidian canvas, per DESIGN-SYSTEM.md §2 "Splash". Framework-drawn on API 31+; the
         compat library paints the same background+icon itself on 26-30, so minSdk 26 gets a uniform
         result either way. MainActivity.installSplashScreen() wires the exit transition and honors
         reduced motion; postSplashScreenTheme hands off to the real app theme once that fires. -->
    <style name="Theme.VortX.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/vortx_canvas</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_vortx_mark</item>
        <item name="postSplashScreenTheme">@style/Theme.VortX</item>
    </style>
</resources>
