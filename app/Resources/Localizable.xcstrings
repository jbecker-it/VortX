{
  "sourceLanguage": "en",
  "strings": {
    "@%@": {},
    "%@": {},
    "%@ · tap to get it": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ · tocca per ottenerlo"
          }
        }
      }
    },
    "%@ (%@)": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ (%2$@)"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ (%@)"
          }
        }
      }
    },
    "%@ can only be edited from that profile": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ può essere modificato solo da quel profilo"
          }
        }
      }
    },
    "%@ other add-on%@ returned no sources for this title.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ other add-on%2$@ returned no sources for this title."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ altro componente aggiuntivo%@ non ha restituito sorgenti per questo titolo."
          }
        }
      }
    },
    "%@: %@": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@: %2$@"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@: %@"
          }
        }
      }
    },
    "%@. %@": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@. %2$@"
          }
        }
